mixin form-change-multi(path)
    form(
        action=path
        method="POST"
        form-change-multi
    )
        .d-flex.align-items-start

            .me-2
                select(
                    name="type"
                    class="form-select mb-2"
                )
                    option(value="" selected disabled)
                        | -- Chọn hành động --

                    option(value="active")
                        | Hoạt động

                    option(value="inactive")
                        | Dừng hoạt động

                    option(value="delete-all")
                        | Xóa tất cả

                    option(value="change-position")
                        | Thay đổi vị trí

            .me-2
                input(
                    type="text"
                    name="ids"
                    value=""
                    class="form-control d-none"
                )

            button(
                type="submit"
                class="btn btn-primary mb-2"
            ) Áp dụng