mixin pagination(pagination)
    nav
        ul(class="pagination")
            if (pagination.currentPage > 1)
                li(class="page-item")
                    button(
                        class="page-link"
                        button-pagination=1
                    ) Trang đầu

                li(class="page-item")
                    button(
                        class="page-link"
                        button-pagination=pagination.currentPage - 1
                    ) Trang trước

            - var startPage = Math.max(1, pagination.currentPage - 3)
            - var endPage = Math.min(pagination.currentPage + 3, pagination.totalPage)
            - for (var i = startPage; i <= endPage; i++)
                li(class=`page-item ${pagination.currentPage == i ? "active" : ""}`)
                    button(
                        class="page-link"
                        button-pagination=i
                    ) #{i}

            if (pagination.currentPage < pagination.totalPage)
                li(class="page-item")
                    button(
                        class="page-link"
                        button-pagination=pagination.currentPage + 1
                    ) Trang tiếp

                li(class="page-item")
                    button(
                        class="page-link"
                        button-pagination=pagination.totalPage
                    ) Trang cuối