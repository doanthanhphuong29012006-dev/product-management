extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    h1.mb-4 Thêm mới tài khoản

    +alert-error(500)
    
    if (roles)
        form(
            action=`${prefixAdmin}/accounts/create`
            method="POST"
            enctype="multipart/form-data"
        )
        
            .mb-3
                label.form-label(for="fullName") Họ tên *
                input.form-control(
                    type="text"
                    id="fullName"
                    name="fullName"
                    required
                )

            .mb-3
                label.form-label(for="email") Email *
                input.form-control(
                    type="email"
                    id="email"
                    name="email"
                    required
                )

            .mb-3
                label.form-label(for="password") Mật khẩu *
                input.form-control(
                    type="password"
                    id="password"
                    name="password"
                    required
                )

            .mb-3
                label.form-label(for="phone") Số điện thoại
                input.form-control(
                    type="text"
                    id="phone"
                    name="phone"
                )

            .mb-3(upload-image)
                label.form-label(for="avatar") Avatar

                input.form-control(
                    type="file"
                    id="avatar"
                    name="avatar"
                    accept="image/*"
                    upload-image-input
                )

                img.image-preview(
                    src=""
                    upload-image-preview
                )

            .mb-3
                label.form-label(for="role_id") Phân quyền

                select.form-select(
                    id="role_id"
                    name="role_id"
                    required
                )
                    option(value="" selected disabled) -- Chọn --
                    each item in roles
                        option(value=item.id) #{item.title}

            .form-check.form-check-inline.mb-3
                input.form-check-input(
                    type="radio"
                    id="statusActive"
                    name="status"
                    value="active"
                    checked
                )
                label.form-check-label(for="statusActive")
                    | Hoạt động

            .form-check.form-check-inline.mb-3
                input.form-check-input(
                    type="radio"
                    id="statusInActive"
                    name="status"
                    value="inactive"
                )
                label.form-check-label(for="statusInActive")
                    | Dừng hoạt động

            button.btn.btn-primary(
                type="submit"
            ) Tạo mới

    else
        p Vui lòng tạo nhóm quyền trước khi cập nhật tài khoản
        p   
            a(
                href=`${prefixAdmin}/roles/create`
                class="btn btn-secondary"
            ) Tạo nhóm quyền