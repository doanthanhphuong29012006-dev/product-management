extends ../../layouts/default.pug
include ../../mixins/moment.pug

block main
    .container-fluid.my-4
        .card.product-admin-card
            .card-header.d-flex.justify-content-between.align-items-center
                h4.mb-0.title-pink 
                    i.fas.fa-info-circle.me-2
                    | Chi tiết: #{product.title}
                
                if (role.permissions.includes("products_edit"))
                    a.btn.btn-warning.btn-sm(href=`${prefixAdmin}/products/edit/${product.id}`) 
                        | Chỉnh sửa sản phẩm

            .card-body.p-4
                .row
                    .col-md-4.text-center.mb-4.mb-md-0
                        if (product.thumbnail)
                            .admin-img-wrapper.mb-3
                                img.img-fluid(src=product.thumbnail alt=product.title)
                        
                        if (product.status)
                            .status-box
                                span.fw-bold.text-muted.me-2 Trạng thái:
                                if (product.status === "active")
                                    span.badge.bg-success.px-3.py-2 Hoạt động
                                else
                                    span.badge.bg-danger.px-3.py-2 Dừng hoạt động

                    .col-md-8
                        .info-group.mb-4
                            h5.text-pink.fw-bold Thông tin bán hàng
                            hr.text-pink.opacity-25
                            .row.g-3
                                .col-sm-6
                                    .stat-box
                                        span.text-muted Giá gốc: 
                                        strong.text-dark #{product.price}$
                                .col-sm-6
                                    .stat-box
                                        span.text-muted Giảm giá: 
                                        span.badge.bg-danger -#{product.discountPercentage}%
                                .col-sm-6
                                    .stat-box
                                        span.text-muted Giá thực bán: 
                                        - var newPrice = (product.price * (100 - product.discountPercentage) / 100).toFixed(0)
                                        strong.text-danger.fs-5 #{newPrice}$
                                .col-sm-6
                                    .stat-box
                                        span.text-muted Tồn kho: 
                                        strong.text-dark #{product.stock} sản phẩm
                                .col-sm-6
                                    .stat-box
                                        span.text-muted Vị trí hiển thị: 
                                        strong.text-dark #{product.position}

                        .info-group.mb-4
                            h5.text-pink.fw-bold Lịch sử tạo
                            hr.text-pink.opacity-25
                            .row.g-3
                                if (product.createdBy)
                                    .col-sm-6
                                        .stat-box
                                            span.text-muted Người tạo: 
                                            strong.text-dark #{product.userFullName}
                                    .col-sm-6
                                        .stat-box
                                            span.text-muted Thời gian: 
                                            strong.text-dark 
                                                +formatDateTime(product.createdBy.createdAt)

                if (product.description)
                    .row.mt-4
                        .col-12
                            .info-group
                                h5.text-pink.fw-bold Nội dung mô tả
                                hr.text-pink.opacity-25
                                .desc-box.bg-light.p-4.rounded.border
                                    | !{product.description}

    script(src="/admin/js/product.js")