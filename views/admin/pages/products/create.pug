extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/select-tree.pug

block main
    +alert-error("5000")

    h1.mb-4 Thêm mới sản phẩm

    form(
        action=`${prefixAdmin}/products/create`
        id="form-create-product"
        method="POST"
        enctype="multipart/form-data"
    )

        .mb-3
            label.form-label(for="title") Tiêu đề

            input.form-control(
                type="text"
                id="title"
                name="title"
            )

        .mb-3
            label.form-label(for="product_category_id") Danh mục

            select.form-select(
                id="product_category_id"
                name="product_category_id"
            )
                option(value="") -- Chọn danh mục --

                if (category)
                    +select-tree(category)

        .form-check.form-check-inline.mb-3
            input.form-check-input(
                type="radio"
                id="feature1"
                name="feature"
                value="1"
            )

            label.form-check-label(for="statusActive")
                | Nổi bật

        .form-check.form-check-inline.mb-3
            input.form-check-input(
                type="radio"
                id="feature0"
                name="feature"
                value="0"
                checked
            )

            label.form-check-label(for="statusInActive")
                | Không

        .mb-3
            label.form-label(for="desc") Mô tả

            textarea.form-control.textarea-mce(
                id="desc"
                name="description"
                rows="5"
            )

        .mb-3
            label.form-label(for="price") Giá

            input.form-control(
                type="number"
                id="price"
                name="price"
                value="0"
                min="0"
            )

        .mb-3
            label.form-label(for="discount") % Giảm giá

            input.form-control(
                type="number"
                id="discount"
                name="discountPercentage"
                value="0"
                min="0"
            )

        .mb-3
            label.form-label(for="stock") Số lượng

            input.form-control(
                type="number"
                id="stock"
                name="stock"
                value="0"
                min="0"
            )

        .mb-3(upload-image)
            label.form-label(for="thumbnail") Ảnh

            input.form-control(
                type="file"
                id="thumbnail"
                name="thumbnail"
                accept="image/*"
                upload-image-input
            )

            img.image-preview(
                src=""
                upload-image-preview
            )

        .mb-3
            label.form-label(for="position") Vị trí

            input.form-control(
                type="number"
                id="position"
                name="position"
                placeholder="Tự động tăng"
                min="1"
            )

        .form-check.form-check-inline.mb-3
            input.form-check-input(
                type="radio"
                id="statusActive"
                name="status"
                value="active"
                checked
            )

            label.form-check-label(for="statusActive")
                | Hoạt động

        .form-check.form-check-inline.mb-3
            input.form-check-input(
                type="radio"
                id="statusInActive"
                name="status"
                value="inactive"
            )

            label.form-check-label(for="statusInActive")
                | Dừng hoạt động

        button.btn.btn-primary(
            type="submit"
        ) Tạo mới

    script(src="/admin/js/product.js")