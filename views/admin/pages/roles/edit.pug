extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error("5000")
    +alert-success("5000")

    h1(class="mb-4") Chỉnh sửa nhóm quyền

    form(
        action=`${prefixAdmin}/roles/edit/${record.id}?_method=PATCH`
        method="POST"
    )
        .mb-3
            label.form-label(for="title") Tiêu đề
            input.form-control(
                type="text"
                id="title"
                name="title"
                value=record.title
                required
            )

        .mb-3
            label.form-label(for="desc") Mô tả
            input.form-control(
                type="text"
                id="desc"
                name="description"
                value=record.description
            )

        button.btn.btn-primary(
            type="submit"
        ) Cập nhật