doctype html 
html 
    head 
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css")
        link(rel="stylesheet", href="/admin/css/style.css")

        link(rel="icon", type="image/png", href="/images/pig-logo1.png")

        title #{pageTitle} 

    body 
        if (role.permissions.length > 0)
            include ../partials/header.pug
            .body 
                include ../partials/sider.pug 

                .main 
                    block main
        else 
            include ../../client/pages/errors/404.pug

    //- TinyMCE
    script(src="https://cdn.tiny.cloud/1/2nujizgf04p41obiw1m88wt6hfqohdgog20h4vqnnqhzypbt/tinymce/7/tinymce.min.js" referrerpolicy="origin")
    script(src="/admin/js/tinymce-config.js")
    //- End TinyMCE

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js")
    script(src="/admin/js/script.js")