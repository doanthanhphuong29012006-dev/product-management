extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-lg-5.col-md-7
                .auth-card
                    .text-center.mb-4
                        h2.title-pink.mt-2 Đăng nhập

                    form(
                        action="/user/login"
                        method="POST"
                    )
                        .mb-3
                            label.form-label.fw-bold.text-pink(for="email") Email
                            input.form-control.input-pink(
                                type="email"
                                id="email"
                                name="email"
                                placeholder="Nhập email của bạn..."
                                required
                            )

                        .mb-3
                            label.form-label.fw-bold.text-pink(for="password") Mật khẩu
                            input.form-control.input-pink(
                                type="password"
                                id="password"
                                name="password"
                                placeholder="••••••••"
                            )

                        .d-flex.justify-content-end.mb-4
                            a.forgot-link(href="/user/password/forgot") Quên mật khẩu?

                        button.btn.btn-hero-pink.w-100(
                            type="submit"
                        ) Đăng nhập ngay

                    .text-center.mt-4
                        span.text-muted Chưa có tài khoản? 
                        a.register-link(href="/user/register") Đăng ký ngay