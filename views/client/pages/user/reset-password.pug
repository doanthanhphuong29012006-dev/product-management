extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .row.justify-content-center
            .col-8
                h1(class="text-center mb-4") Đổi mật khẩu
                
                form(
                    action="/user/password/reset"
                    method="POST"
                )
                    div(class="mb-3")
                        label(for="password" class="form-label") Mật khẩu mới
                        input(
                            type="password"
                            class="form-control"
                            id="password"
                            name="password"
                        )
                        
                    div(class="mb-3")
                        label(for="confirmPassword" class="form-label") Xác nhận mật khẩu
                        input(
                            type="password"
                            class="form-control"
                            id="confirmPassword"
                            name="confirmPassword"
                        )
                        
                    div(class="mb-3")
                        button(
                            type="submit"
                            class="btn btn-primary w-100"
                        ) Đổi mật khẩu