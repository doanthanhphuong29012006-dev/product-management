extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .row.justify-content-center
            .col-lg-5.col-md-7
                .auth-card
                    .text-center.mb-4
                        h2.title-pink.mt-2 Đổi mật khẩu
                        p.text-muted.mt-2 Hãy thiết lập mật khẩu mới cho tài khoản của bạn

                    form(
                        action="/user/password/reset"
                        method="POST"
                    )
                        .mb-3
                            label.form-label.fw-bold.text-pink(for="password") Mật khẩu mới
                            input.form-control.input-pink(
                                type="password"
                                id="password"
                                name="password"
                                placeholder="Nhập mật khẩu mới..."
                            )
                            
                        .mb-4
                            label.form-label.fw-bold.text-pink(for="confirmPassword") Xác nhận mật khẩu
                            input.form-control.input-pink(
                                type="password"
                                id="confirmPassword"
                                name="confirmPassword"
                                placeholder="Nhập lại mật khẩu..."
                            )
                            
                        button.btn.btn-hero-pink.w-100(
                            type="submit"
                        ) Cập nhật mật khẩu