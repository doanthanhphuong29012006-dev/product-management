extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-lg-5.col-md-7
                .auth-card
                    .text-center.mb-4
                        h2.title-pink.mt-2 Nhập mã xác thực
                        p.text-muted.mt-2 Mã OTP gồm 6 chữ số đã được gửi đến email của bạn

                    form(
                        action="/user/password/otp"
                        method="POST"
                    )
                        .mb-3
                            label.form-label.fw-bold.text-pink(for="email") Email nhận mã
                            input.form-control.input-pink(
                                type="email"
                                id="email"
                                name="email"
                                required
                                value=email
                                readonly
                            )
                            
                        .mb-4
                            label.form-label.fw-bold.text-pink(for="otp") Mã OTP
                            input.form-control.input-pink(
                                type="text"
                                id="otp"
                                name="otp"
                                placeholder="Nhập mã 6 chữ số..."
                            )
                            
                        button.btn.btn-hero-pink.w-100(
                            type="submit"
                        ) Xác nhận mã OTP

                    .text-center.mt-4
                        a.register-link(href="/user/password/forgot") Nhập lại email khác