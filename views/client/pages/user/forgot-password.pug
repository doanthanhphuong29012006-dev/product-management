extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-lg-5.col-md-7
                .auth-card
                    .text-center.mb-4
                        h2.title-pink.mt-2 Lấy lại mật khẩu
                        p.text-muted.mt-2 Vui lòng nhập email để nhận mã xác nhận OTP

                    form(
                        action="/user/password/forgot"
                        method="POST"
                    )
                        .mb-4
                            label.form-label.fw-bold.text-pink(for="email") Email đăng ký
                            input.form-control.input-pink(
                                type="email"
                                id="email"
                                name="email"
                                placeholder="Nhập email của bạn..."
                                required
                            )
                            
                        button.btn.btn-hero-pink.w-100(
                            type="submit"
                        ) Gửi mail xác nhận

                    .text-center.mt-4
                        a.register-link(href="/user/login") Quay lại trang Đăng nhập