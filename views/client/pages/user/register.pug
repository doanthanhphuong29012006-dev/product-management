extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-lg-5.col-md-7
                .auth-card
                    .text-center.mb-4
                        h2.title-pink.mt-2 Đăng ký tài khoản

                    form(
                        action="/user/register"
                        method="POST"
                    )
                        .mb-3
                            label.form-label.fw-bold.text-pink(for="fullName") Họ và tên
                            input.form-control.input-pink(
                                type="text"
                                id="fullName"
                                name="fullName"
                                placeholder="Nhập họ và tên..."
                                required
                            )

                        .mb-3
                            label.form-label.fw-bold.text-pink(for="email") Email
                            input.form-control.input-pink(
                                type="email"
                                id="email"
                                name="email"
                                placeholder="Nhập email của bạn..."
                                required
                            )

                        .mb-3
                            label.form-label.fw-bold.text-pink(for="password") Mật khẩu
                            input.form-control.input-pink(
                                type="password"
                                id="password"
                                name="password"
                                placeholder="••••••••"
                            )

                        button.btn.btn-hero-pink.w-100.mt-4(
                            type="submit"
                        ) Đăng ký ngay

                    .text-center.mt-4
                        span.text-muted Đã có tài khoản? 
                        a.register-link(href="/user/login") Đăng nhập tại đây