extends ../../layouts/default.pug 
include ../../mixins/box-head.pug
include ../../mixins/product-layout.pug

block main
    .hero-section
        .container.text-center
            img.hero-pig(src="/images/pig-logo1.png", alt="Pig Mascot")
            h1.hero-title Chào mừng đến với Shop của Phương!
            p.hero-desc Nơi cung cấp những sản phẩm dễ thương, chất lượng và ngập tràn màu hồng dành riêng cho bạn.
            a.btn.btn-hero-pink(href="/products") Khám phá sản phẩm ngay

    .section-products-featured.my-5
    .container
        .row
            .col-12
                +box-head("Sản phẩm nổi bật")

        .row
            +product-grid(productsFeatured)