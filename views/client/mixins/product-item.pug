mixin product-item(item)
    .col-lg-3.col-md-4.col-sm-6.mb-4
        .product-item
            .inner-image
                img(src=item.thumbnail, alt=item.title)
            if (item.feature == "1")
                .inner-featured Nổi bật

            .inner-content
                h3.inner-title
                    a(href=`/products/detail/${item.slug}`) #{item.title}

                .inner-price-new #{item.newPrice}đ
                .inner-price-old #{item.price}đ
                .inner-discount -#{item.discountPercentage}%