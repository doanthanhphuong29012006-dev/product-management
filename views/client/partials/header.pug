include ../mixins/sub-menu.pug

header.header
    .container
        .row.align-items-center

            .col-4
                .inner-logo
                    a(href="/").d-flex.align-items-center
                        img(src="/images/pig-logo1.png", alt="Logo")
                        span.fw-bold.ms-2.text-pink ShoPhuongDT

            .col-8
                .inner-menu
                    ul
                        li
                            a(href="/") Trang chủ

                        li(class="sub-menu")
                            - const pathProduct = "/products"
                            a(href=pathProduct) Sản phẩm
                            +sub-menu(layoutProductsCategory, pathProduct)